{
  "version": "1.0",
  "runtime": "python3.11",
  "build": {
    "commands": [
      "echo 'Building FastAPI backend...' &&",
      "pip install --no-cache-dir -r requirements.txt"
    ]
  },
  "run": {
    "runtime": "python3.11",
    "command": [
      "uvicorn",
      "main:app",
      "--host",
      "0.0.0.0",
      "--port",
      "8000"
    ]
  },
  "port": 8000,
  "environment": [
    {
      "name": "PORT",
      "value": "8000"
    },
    {
      "name": "TOGETHER_API_KEY",
      "value": "${TOGETHER_API_KEY}"
    },
    {
      "name": "GEMINI_API_KEY", 
      "value": "${GEMINI_API_KEY}"
    },
    {
      "name": "EMAIL_HOST",
      "value": "${EMAIL_HOST}"
    },
    {
      "name": "EMAIL_PORT",
      "value": "${EMAIL_PORT}"
    },
    {
      "name": "EMAIL_USER",
      "value": "${EMAIL_USER}"
    },
    {
      "name": "EMAIL_PASSWORD",
      "value": "${EMAIL_PASSWORD}"
    }
  ]
}
